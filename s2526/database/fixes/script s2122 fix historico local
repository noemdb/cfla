-- Paso 2 INSERT 

INSERT INTO s2526.hnotas (
    pensum_id,
    grupo_estable_id,
    tevaluacion_id,
    estudiant_id,
    historico_nota_id,
    institucion_id,
    valor,
    literal,
    tipo,
    fecha,
    description,
    observations,
    user_id,
    deleted_at,
    created_at,
    updated_at
)
SELECT
    h.pensum_id,
    h.grupo_estable_id,
    h.tevaluacion_id,
    h.estudiant_id,
    s2526_hn.id AS historico_nota_id_destino,
    h.institucion_id,
    h.valor,
    h.literal,
    h.tipo,
    h.fecha,
    h.description,
    h.observations,
    h.user_id,
    h.deleted_at,
    h.created_at,
    h.updated_at
FROM s2122.hnotas AS h
LEFT JOIN s2526.historico_notas AS s2526_hn
       ON s2526_hn.temp_hn_id = CONCAT('s2122_', h.historico_nota_id)
LEFT JOIN s2526.hnotas AS d
       ON d.pensum_id    = h.pensum_id
      AND d.estudiant_id = h.estudiant_id     -- clave lógica usada ahora
WHERE h.estudiant_id IN (214)
  AND d.id IS NULL
  AND h.valor IS NOT NULL; 

-- --------------------------

SELECT
    h.id AS id_hnota_origen,
    h.pensum_id,
    h.estudiant_id,
    s2526_hn.id AS historico_nota_id_destino,
    h.historico_nota_id AS historico_nota_origen,
    
    h.grupo_estable_id,
    h.tevaluacion_id,
    h.institucion_id,
    h.valor,
    h.literal,
    h.tipo,
    h.fecha,
    h.description,
    h.observations,
    h.user_id,
    h.deleted_at,
    h.created_at,
    h.updated_at
FROM s2122.hnotas AS h
LEFT JOIN s2526.historico_notas AS s2526_hn
       ON s2526_hn.temp_hn_id = CONCAT('s2122_', h.historico_nota_id)
LEFT JOIN s2526.hnotas AS d
       ON d.pensum_id    = h.pensum_id
      AND d.estudiant_id = h.estudiant_id   -- clave lógica usada ahora
WHERE h.estudiant_id IN (214)
  AND d.id IS NULL
  AND h.valor IS NOT NULL
  ;